<Window x:Class="PdfDrive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Drive"
        Width="820" Height="640" MinWidth="640" MinHeight="460"
        Background="{DynamicResource BgDarkBrush}"
        AllowDrop="True"
        Drop="Window_Drop" DragOver="Window_DragOver"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Шапка в стиле GardenPlanner ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}"
                CornerRadius="12" Padding="16,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleLabel" Text="PDF Drive"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}" />
                    <TextBlock x:Name="SubLabel"
                               FontSize="12"
                               Foreground="{DynamicResource HeaderSubBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="LangCombo" Width="120" Margin="0,0,8,0"
                              SelectionChanged="LangCombo_SelectionChanged"
                              VerticalContentAlignment="Center" />
                    <Button x:Name="ThemeBtn" Style="{StaticResource GhostButton}"
                            Foreground="{DynamicResource HeaderTextBrush}"
                            Click="ThemeBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Панель действий ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="AddBtn" Style="{StaticResource RoundButton}" Click="AddBtn_Click" />
                <Button x:Name="ClearBtn" Style="{StaticResource GhostButton}"
                        Margin="8,0,0,0" Click="ClearBtn_Click" />
            </StackPanel>

            <CheckBox x:Name="OpenAfterSaveChk" Grid.Column="1"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      FontSize="13"
                      Checked="OpenAfterSaveChk_Changed"
                      Unchecked="OpenAfterSaveChk_Changed" />
        </Grid>

        <!-- ═══ Список файлов ═══ -->
        <Border Grid.Row="2" Background="{DynamicResource BgCardBrush}"
                CornerRadius="12" Padding="6"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
            <Grid>
                <ListBox x:Name="FilesList"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgInputBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                           FontSize="16" VerticalAlignment="Center"
                                           Margin="2,0,10,0" />

                                <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="14" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Column="2" Text="{Binding PagesText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center"
                                           MinWidth="48" TextAlignment="Right" Margin="0,0,12,0" />

                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                    <Button Content="▲" Style="{StaticResource IconButton}"
                                            Margin="0,0,4,0" Click="MoveUp_Click" Tag="{Binding}" />
                                    <Button Content="▼" Style="{StaticResource IconButton}"
                                            Margin="0,0,4,0" Click="MoveDown_Click" Tag="{Binding}" />
                                    <Button Content="✕" Style="{StaticResource IconButton}"
                                            Background="{DynamicResource DangerBrush}"
                                            Click="Remove_Click" Tag="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="EmptyHint"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="380" />
            </Grid>
        </Border>

        <!-- ═══ Низ: статус + предпросмотр + сохранить ═══ -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusLabel" Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="13" TextTrimming="CharacterEllipsis" Margin="4,0,12,0" />

            <Button x:Name="PreviewBtn" Grid.Column="1"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,0" Click="PreviewBtn_Click" />

            <Button x:Name="SaveBtn" Grid.Column="2"
                    Style="{StaticResource RoundButton}" Click="SaveBtn_Click" />
        </Grid>
    </Grid>
</Window>
